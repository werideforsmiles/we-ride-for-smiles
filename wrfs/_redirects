# Canonical: strip .html from the address bar
/:lang/index.html    /:lang/          301!
/:lang/:page.html    /:lang/:page     301!

# Serve clean URLs (rewrite to real files)
/:lang/              /:lang/index.html  200
/:lang/:page         /:lang/:page.html  200

# Root → language by browser preference
/   /fr/   302   Language=fr
/   /es/   302   Language=es
/   /en/   302
